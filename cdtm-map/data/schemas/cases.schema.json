{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cases",
  "type": "array",
  "description": "Liste de donnees RP rattachees aux cases cartographiques.",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "id_case": {
        "type": "string"
      },
      "region": {
        "type": ["string", "null"]
      },
      "sous_region": {
        "type": ["string", "null"]
      },
      "terrain_cat": {
        "type": "string",
        "enum": ["plaine", "desert", "marais", "foret", "montagne", "inconnu"]
      },
      "terrain_type": {
        "type": "string",
        "enum": [
          "prairie",
          "plaine_aride",
          "bocage",
          "desert_chaud",
          "desert_gele",
          "terre_desolee",
          "marais",
          "foret",
          "foret_luxuriante",
          "taiga",
          "colline",
          "montagne",
          "montagne_riche",
          "paturage",
          "inconnu"
        ]
      },
      "terrain_secondaire": {
        "type": ["string", "null"],
        "enum": [
          "prairie",
          "plaine_aride",
          "bocage",
          "desert_chaud",
          "desert_gele",
          "terre_desolee",
          "foret",
          "foret_luxuriante",
          "taiga",
          "inconnu",
          null
        ]
      },
      "cote": {
        "type": ["boolean", "null"]
      },
      "faction": {
        "type": ["string", "null"]
      },
      "peuple_majoritaire": {
        "type": ["string", "null"]
      },
      "empl_base": {
        "type": ["integer", "null"],
        "minimum": 0
      },
      "empl_max": {
        "type": ["integer", "null"],
        "minimum": 1,
        "maximum": 5
      },
      "controleur": {
        "type": ["string", "null"]
      },
      "controle_type": {
        "type": ["string", "null"],
        "enum": ["aucun", "total", "partiel", "conteste", "occupe", "vassalise", "inconnu", null]
      },
      "note_publique": {
        "type": ["string", "null"]
      },
      "note_staff": {
        "type": ["string", "null"]
      }
    },
    "required": ["id_case", "terrain_cat", "terrain_type"],
    "allOf": [
      {
        "if": {
          "properties": { "terrain_cat": { "const": "plaine" } },
          "required": ["terrain_cat"]
        },
        "then": {
          "properties": {
            "terrain_type": { "enum": ["prairie", "plaine_aride", "bocage"] }
          }
        }
      },
      {
        "if": {
          "properties": { "terrain_cat": { "const": "desert" } },
          "required": ["terrain_cat"]
        },
        "then": {
          "properties": {
            "terrain_type": { "enum": ["desert_chaud", "desert_gele", "terre_desolee"] }
          }
        }
      },
      {
        "if": {
          "properties": { "terrain_cat": { "const": "marais" } },
          "required": ["terrain_cat"]
        },
        "then": {
          "properties": {
            "terrain_type": { "const": "marais" }
          }
        }
      },
      {
        "if": {
          "properties": { "terrain_cat": { "const": "foret" } },
          "required": ["terrain_cat"]
        },
        "then": {
          "properties": {
            "terrain_type": { "enum": ["foret", "foret_luxuriante", "taiga"] }
          }
        }
      },
      {
        "if": {
          "properties": { "terrain_cat": { "const": "montagne" } },
          "required": ["terrain_cat"]
        },
        "then": {
          "properties": {
            "terrain_type": { "enum": ["colline", "montagne", "montagne_riche", "paturage"] }
          }
        }
      },
      {
        "if": {
          "properties": { "terrain_cat": { "const": "inconnu" } },
          "required": ["terrain_cat"]
        },
        "then": {
          "properties": {
            "terrain_type": { "const": "inconnu" }
          }
        }
      },
      {
        "if": {
          "not": {
            "properties": { "terrain_type": { "const": "colline" } },
            "required": ["terrain_type"]
          }
        },
        "then": {
          "properties": {
            "terrain_secondaire": { "type": "null" }
          }
        }
      }
    ]
  }
}
