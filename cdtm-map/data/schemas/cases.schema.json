{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cases",
  "type": "array",
  "description": "Liste des attributs stables rattachés aux géométries des cases cartographiques.",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "id_case": {
        "type": "string",
        "minLength": 1
      },
      "region": {
        "type": [
          "string",
          "null"
        ]
      },
      "sous_region": {
        "type": [
          "string",
          "null"
        ]
      },
      "cote": {
        "type": [
          "boolean",
          "null"
        ]
      },
      "lac_majeur": {
        "type": [
          "boolean",
          "null"
        ]
      },
      "cours_eau_majeur": {
        "type": [
          "boolean",
          "null"
        ]
      }
    },
    "required": [
      "id_case"
    ]
  }
}
