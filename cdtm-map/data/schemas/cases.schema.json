{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cases",
  "type": "array",
  "description": "Liste de donnees RP rattachees aux cases cartographiques.",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "id_case": {
        "type": "string"
      },
      "region": {
        "type": ["string", "null"]
      },
      "sous_region": {
        "type": ["string", "null"]
      },
      "terrain_cat": {
        "type": ["string", "null"],
        "enum": ["plaine", "desert", "marais", "foret", "montagne", "inconnu", null]
      },
      "terrain_type": {
        "type": ["string", "null"]
      },
      "terrain_secondaire": {
        "type": ["string", "null"]
      },
      "faction": {
        "type": ["string", "null"]
      },
      "peuple_majoritaire": {
        "type": ["string", "null"]
      },
      "empl_base": {
        "type": ["integer", "null"],
        "minimum": 0
      },
      "empl_max": {
        "type": ["integer", "null"],
        "minimum": 0
      },
      "controleur": {
        "type": ["string", "null"]
      },
      "controle_type": {
        "type": ["string", "null"],
        "enum": ["aucun", "total", "partiel", "conteste", "occupe", "vassalise", "inconnu", null]
      },
      "note_publique": {
        "type": ["string", "null"]
      },
      "note_staff": {
        "type": ["string", "null"]
      }
    },
    "required": ["id_case"]
  }
}
