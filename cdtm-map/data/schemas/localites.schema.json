{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "localites",
  "type": "array",
  "description": "Liste de localites rattachees a une case ou a une geometrie future.",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "id_localite": {
        "type": "string"
      },
      "id_case": {
        "type": ["string", "null"]
      },
      "nom": {
        "type": ["string", "null"]
      },
      "niveau": {
        "type": ["string", "null"],
        "enum": ["hameau", "village", "bourg", "ville", "cite", null]
      },
      "type": {
        "type": ["string", "null"],
        "enum": ["avant_poste", "fort", "domaine", "ruine", null]
      },
      "empl": {
        "type": ["integer", "null"],
        "minimum": 0
      }
    },
    "required": ["id_localite"]
  }
}
