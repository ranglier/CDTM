{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/cdtm/schemas/localites.schema.json",
  "title": "CDTM Localite",
  "type": "object",
  "additionalProperties": true,
  "required": ["id_localite", "id_case"],
  "properties": {
    "id_localite": { "type": "string" },
    "id_case": { "type": "string" },
    "nom": { "type": "string" },
    "niveau": { "type": "string" },
    "type": { "type": "string" },
    "faction": { "type": "string" },
    "controleur": { "type": "string" },
    "race": { "type": "string" },
    "fortifie": { "type": ["boolean", "null"] },
    "note_publique": { "type": "string" },
    "note_staff": { "type": "string" }
  }
}
